{
  "uid": "llm-cache-pipeline",
  "title": "Cache & Gateway Stages",
  "description": "Semantic cache effectiveness and per-stage / per-downstream timing observed from the gateway side. Cache hit/miss/error semantics come from gateway/stages.go::handleCacheLookupStage.",
  "tags": ["llm-gateway", "p5"],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "30s",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cache lookup result (stacked)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(gateway_cache_lookup_total[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 40, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hit" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } }] },
          { "matcher": { "id": "byName", "options": "miss" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red"    } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache hit ratio (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gateway_cache_lookup_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(gateway_cache_lookup_total[5m])), 1e-9)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "orange","value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache lookup p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gateway_cache_lookup_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gateway_cache_lookup_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Gateway HTTP latency heatmap (/v1/chat/completions)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (increase(gateway_http_duration_seconds_bucket{path=\"/v1/chat/completions\"}[$__rate_interval]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "scaleDistribution": { "type": "linear" }, "hideFrom": { "tooltip": false, "viz": false, "legend": false } } },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": { "axisPlacement": "left", "unit": "s" },
        "color": { "mode": "scheme", "scheme": "Spectral", "steps": 64, "reverse": false, "exponent": 0.5 },
        "cellGap": 1,
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "tooltip": { "mode": "single", "yHistogram": false, "showColorScale": false }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "gRPC client p95 latency (gateway → downstream)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, grpc_service, grpc_method) (rate(grpc_client_handling_time_seconds_bucket{service=\"gateway\"}[$__rate_interval])))",
          "legendFormat": "{{grpc_service}}/{{grpc_method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Gateway in-flight HTTP requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "gateway_http_in_flight",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    }
  ]
}
