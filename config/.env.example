# =============================================================================
# llm_gateway — environment template
# Copy to project root as .env, then fill in real values.
#
#   cp config/.env.example .env
#
# See config/README.md for index of all example configs.
# See README.md "Configuration Reference" for full variable docs.
# =============================================================================

# ----- Embedding service -----------------------------------------------------
#
# Two providers are supported: `openai` and `ollama`. Pick one block and
# comment out the other. EMBED_DIMENSIONS must match the chosen model's true
# output size — embedding-service does a probe at startup and refuses to start
# on mismatch.

# Provider: openai (default, OpenAI-compatible HTTP API)
EMBED_PROVIDER=openai
EMBED_API_KEY=sk-your-embedding-api-key
EMBED_ENDPOINT=https://api.openai.com/v1/embeddings
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536

# Provider: ollama (local /api/embed). Use with the overlay
#   docker compose -f docker-compose.yml -f config/docker-compose.ollama.yml up
# The overlay puts embedding-service in host network mode so `localhost`
# reaches the host's ollama daemon directly. EMBED_API_KEY stays blank for the
# default unauthenticated ollama; set it only if a reverse proxy adds auth.
# EMBED_PROVIDER=ollama
# EMBED_API_KEY=
# EMBED_ENDPOINT=http://localhost:11434/api/embed
# EMBED_MODEL=qwen3-embedding:0.6b
# EMBED_DIMENSIONS=1024

# ----- Cache service ---------------------------------------------------------
#
# Two store providers are supported: `qdrant` and `redis_hnsw`. Pick one block
# and comment out the other. The redis_hnsw block additionally requires the
# overlay `config/docker-compose.hnsw.yml` to start the redis-stack container.

CACHE_MODE=semantic
CACHE_BUFFER_SIZE=1000
CACHE_WORKER_COUNT=5

# Store provider: qdrant (default, standalone Qdrant container)
CACHE_STORE_PROVIDER=qdrant
QDRANT_COLLECTION_NAME=llm_semantic_cache
QDRANT_SIMILARITY_THRESHOLD=0.95

# Store provider: redis_hnsw (Redis Stack + RediSearch HNSW index). Activate
# with the overlay
#   docker compose -f docker-compose.yml -f config/docker-compose.hnsw.yml up
# All REDIS_HNSW_* variables have defaults baked into the binary — override
# only what you need to tune.
# CACHE_STORE_PROVIDER=redis_hnsw
# REDIS_HNSW_ADDR=redis-stack:6379          # container DNS name on ai-net
# REDIS_HNSW_PASSWORD=                       # leave blank if no AUTH
# REDIS_HNSW_DB=0
# REDIS_HNSW_INDEX_NAME=llm_semantic_cache_idx
# REDIS_HNSW_KEY_PREFIX=llm_semantic_cache
# REDIS_HNSW_SIMILARITY_THRESHOLD=0.95
# REDIS_HNSW_DISTANCE_METRIC=COSINE          # COSINE | L2 | IP (threshold semantics differ)
# REDIS_HNSW_M=16                            # HNSW graph degree
# REDIS_HNSW_EF_CONSTRUCTION=200             # build-time candidate set
# REDIS_HNSW_EF_RUNTIME=10                   # query-time candidate set
# REDIS_HNSW_RECORD_TTL_SECONDS=0            # 0 = never expire
# REDIS_HNSW_DIAL_TIMEOUT_MS=5000

# ----- Completion service ----------------------------------------------------
#
# Three configuration sources are supported, in priority order:
#
#   1. COMPL_POOL_CONFIG_FILE  — path to a JSON file (highest priority)
#   2. COMPL_POOL_CONFIG       — inline JSON
#   3. COMPL_ENDPOINT          — legacy single-endpoint fallback (lowest)
#
# See config/pool.example.json and config/pool-minimal.example.json for the
# multi-endpoint JSON format. The variables below cover the legacy path.

# Legacy single-endpoint mode (used if neither COMPL_POOL_CONFIG_FILE nor
# COMPL_POOL_CONFIG is set):
COMPL_API_KEY=sk-your-completion-api-key
COMPL_ENDPOINT=https://api.openai.com/v1/chat/completions

# Multi-endpoint mode — uncomment one of the two and remove the legacy pair:
# COMPL_POOL_CONFIG_FILE=/etc/llm_gateway/pool.json
# COMPL_POOL_CONFIG={"strategy":"weighted_random","max_attempts":3,"endpoints":[{"name":"primary","url":"...","api_key_env":"OPENAI_KEY","weight":1,"enabled":true}]}

# When using multi-endpoint mode, each endpoint's API key must be present in
# the env under the name declared in its `api_key_env` field. Example:
# OPENAI_KEY_PRIMARY=sk-...
# AZURE_KEY_FALLBACK=...

# ----- RAG service (optional) ------------------------------------------------
# Remove RAG_ADDR from the gateway env to disable RAG entirely.
# RAG_QDRANT_COLLECTION_NAME=llm_rag_documents
# RAG_SIMILARITY_THRESHOLD=0.6
# RAG_DEFAULT_TOP_K=3

# ----- Auth (Redis-backed) ---------------------------------------------------
REDIS_DB=0

# ----- Gateway runtime -------------------------------------------------------
# Log level: DEBUG | INFO | ERROR
LOG_LEVEL=ERROR

# Enable /debug/pprof/* on the public port. DO NOT enable in production.
DEBUG_MODE=false

# Admin API secret — REQUIRED to use /admin/* endpoints.
# If unset, all admin requests will be rejected with 403 Forbidden.
# Pass this value via the X-Admin-Secret request header.
ADMIN_SECRET=change-me-to-a-strong-random-secret

# ----- Service discovery (etcd) ----------------------------------------------
# When set, services register themselves under etcd and clients resolve peers
# via etcd:///services/<name> with round_robin balancing. Leave empty to fall
# back to legacy direct *_ADDR dialing (single-instance mode).
ETCD_ENDPOINTS=etcd:2379

# Per-instance advertise address. Defaults to <hostname>:<SERVE_PORT>, which is
# what container schedulers (compose scale, k8s pods) hand out by default.
# Override only when the container's hostname is not reachable by peers.
# EMBEDDING_ADVERTISE_ADDR=
# CACHE_ADVERTISE_ADDR=
# COMPLETION_ADVERTISE_ADDR=
# AUTH_ADVERTISE_ADDR=
# RAG_ADVERTISE_ADDR=
